# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/planning_app?schema=public

# Auth
# Replace with a securely generated random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-use-openssl-rand-hex-32-different
JWT_REFRESH_EXPIRES_IN=7d

# AI provider (placeholders for future implementation)
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=
